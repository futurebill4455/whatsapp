<header class="border-b border-ink/10 bg-white/70 backdrop-blur sticky top-0 z-40">
  <div class="max-w-5xl mx-auto px-4 h-14 flex items-center justify-between gap-4">
    <a href="/" class="font-display text-lg font-semibold tracking-tight text-ink hover:text-sea transition">
      <%= businessName || 'WhatsApp Bot' %>
    </a>
    <nav class="flex items-center gap-1 text-sm">
      <a href="/" class="px-3 py-1.5 rounded-md hover:bg-mist text-ink/80">QR Connect</a>
      <% if (typeof admin !== 'undefined' && admin) { %>
        <a href="/admin" class="px-3 py-1.5 rounded-md hover:bg-mist text-ink/80">Dashboard</a>
        <a href="/admin/settings" class="px-3 py-1.5 rounded-md hover:bg-mist text-ink/80">Settings</a>
        <form action="/admin/logout" method="POST" class="inline">
          <button type="submit" class="px-3 py-1.5 rounded-md text-coral hover:bg-coral/10">Logout</button>
        </form>
      <% } else { %>
        <a href="/admin/login" class="px-3 py-1.5 rounded-md bg-ink text-white hover:bg-sea">Admin</a>
      <% } %>
    </nav>
  </div>
</header>
