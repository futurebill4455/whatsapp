<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · <%= businessName %></title>
  <%- include('../partials/styles') %>
</head>
<body class="font-sans text-ink bg-sand min-h-screen antialiased">
  <%- include('../partials/nav') %>
  <% if (flash) { %>
    <div class="max-w-4xl mx-auto px-4 pt-4">
      <div class="rounded-lg px-4 py-3 text-sm <%= flash.type === 'error' ? 'bg-red-50 text-red-800 border border-red-200' : 'bg-emerald-50 text-emerald-800 border border-emerald-200' %>"><%= flash.message %></div>
    </div>
  <% } %>

  <main class="max-w-4xl mx-auto px-4 py-8 space-y-8 animate-in">
    <div>
      <h1 class="font-display text-3xl font-semibold mb-2">Authorized users</h1>
      <p class="text-ink/60 max-w-2xl">
        Add users with <strong>Name</strong>, <strong>Phone</strong>, and a <strong>Unique Access Code</strong>.
        The bot stays <em>completely silent</em> until that phone sends its assigned code — then it sends only the form link (no welcome text).
        Wrong codes and unknown numbers get <strong>no reply</strong>.
      </p>
    </div>

    <section class="panel p-6 space-y-4">
      <h2 class="font-display text-xl font-semibold">Settings</h2>
      <form method="POST" action="/admin/access/settings" class="space-y-4">
        <label class="flex items-center gap-2 text-sm">
          <input type="checkbox" name="access_control_enabled" value="1" <%= settings.access_control_enabled !== '0' ? 'checked' : '' %> />
          Strict whitelist — ignore all unknown numbers and wrong codes (no reply)
        </label>
        <button type="submit" class="btn btn-primary">Save settings</button>
      </form>
    </section>

    <section class="panel p-6 space-y-4">
      <h2 class="font-display text-xl font-semibold">Add user</h2>
      <form method="POST" action="/admin/access/users" class="grid md:grid-cols-3 gap-3 items-end">
        <div>
          <label class="label" for="name">Name</label>
          <input class="field" id="name" name="name" required placeholder="Rahul Sharma" />
        </div>
        <div>
          <label class="label" for="phone">Phone number</label>
          <input class="field" id="phone" name="phone" required placeholder="9198XXXXXXXX" />
        </div>
        <div>
          <label class="label" for="access_code">Unique access code</label>
          <input class="field" id="access_code" name="access_code" required placeholder="INSU2026" />
        </div>
        <div class="md:col-span-3">
          <button type="submit" class="btn btn-primary">Add authorized user</button>
        </div>
      </form>
    </section>

    <section class="panel p-6">
      <h2 class="font-display text-xl font-semibold mb-4">Users</h2>
      <% if (!users || !users.length) { %>
        <p class="text-sm text-ink/45">No authorized users yet. Add the first one above.</p>
      <% } else { %>
        <div class="table-wrap overflow-x-auto">
          <table class="data w-full text-sm">
            <thead>
              <tr class="text-left text-ink/50 border-b border-ink/10">
                <th class="py-2 pr-3">Name</th>
                <th class="py-2 pr-3">Phone</th>
                <th class="py-2 pr-3">Access code</th>
                <th class="py-2 pr-3">Status</th>
                <th class="py-2">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(function (u) { %>
                <tr class="border-b border-ink/5 align-top">
                  <td class="py-3 pr-3 font-medium"><%= u.name %></td>
                  <td class="py-3 pr-3">+<%= u.phone %></td>
                  <td class="py-3 pr-3"><code class="text-sea"><%= u.access_code %></code></td>
                  <td class="py-3 pr-3">
                    <% if (!u.is_active) { %>
                      <span class="text-ink/45">Inactive</span>
                    <% } else if (u.verified_at) { %>
                      <span class="text-emerald-700">Unlocked</span>
                    <% } else { %>
                      <span class="text-ink/55">Waiting for code</span>
                    <% } %>
                  </td>
                  <td class="py-3">
                    <form method="POST" action="/admin/access/users/<%= u.id %>" class="inline">
                      <input type="hidden" name="_action" value="lock" />
                      <button type="submit" class="text-xs text-ink/60 hover:text-sea mr-2" title="Require code again">Lock</button>
                    </form>
                    <form method="POST" action="/admin/access/users/<%= u.id %>" class="inline" onsubmit="return confirm('Remove <%= u.name %>?');">
                      <input type="hidden" name="_action" value="delete" />
                      <button type="submit" class="text-xs text-coral">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
