<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · <%= businessName %></title>
  <%- include('../partials/styles') %>
</head>
<body class="font-sans text-ink bg-sand min-h-screen antialiased">
  <%- include('../partials/nav') %>

  <main class="max-w-4xl mx-auto px-4 py-8 animate-in">
    <h1 class="font-display text-3xl font-semibold mb-2">Runtime config</h1>
    <p class="text-ink/60 mb-8">All values come from environment variables (no database). Edit <code class="text-sea">.env</code> / Render env and restart.</p>

    <div class="panel p-6 space-y-4 text-sm">
      <div><span class="text-ink/45">BUSINESS_NAME</span><div class="font-medium mt-1"><%= settings.business_name %></div></div>
      <div><span class="text-ink/45">COMPANY_PHONE</span><div class="font-medium mt-1"><%= settings.company_phone || '(missing)' %></div></div>
      <div><span class="text-ink/45">BASE_URL</span><div class="font-medium mt-1 break-all"><%= settings.base_url %></div></div>
      <div><span class="text-ink/45">TRIGGER_KEYWORDS</span><div class="font-medium mt-1"><%= settings.triggers %></div></div>
      <div><span class="text-ink/45">FORM_INTRO</span><pre class="mt-1 whitespace-pre-wrap text-ink/80"><%= settings.form_intro %></pre></div>
      <div><span class="text-ink/45">LINK_MESSAGE</span><pre class="mt-1 whitespace-pre-wrap font-mono text-xs text-ink/80"><%= settings.link_message %></pre></div>
    </div>
  </main>
</body>
</html>
