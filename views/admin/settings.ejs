<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · <%= businessName %></title>
  <%- include('../partials/styles') %>
</head>
<body class="font-sans text-ink bg-sand min-h-screen antialiased">
  <%- include('../partials/nav') %>
  <% if (flash) { %>
    <div class="max-w-4xl mx-auto px-4 pt-4">
      <div class="rounded-lg px-4 py-3 text-sm <%= flash.type === 'error' ? 'bg-red-50 text-red-800 border border-red-200' : 'bg-emerald-50 text-emerald-800 border border-emerald-200' %>"><%= flash.message %></div>
    </div>
  <% } %>

  <main class="max-w-4xl mx-auto px-4 py-8 animate-in">
    <h1 class="font-display text-3xl font-semibold mb-2">Auto-reply messages</h1>
    <p class="text-ink/60 mb-8">Simple replies for greetings and other inbound messages. No forms or workflows.</p>

    <form method="POST" action="/admin/settings" class="panel p-6 space-y-5">
      <div>
        <label class="label" for="business_name">Business name</label>
        <input class="field" id="business_name" name="business_name" value="<%= settings.business_name || '' %>" />
      </div>
      <div>
        <label class="label" for="welcome_message">Greeting reply (Hi / Hello / Hey)</label>
        <textarea class="field" id="welcome_message" name="welcome_message" rows="4"><%= settings.welcome_message || '' %></textarea>
      </div>
      <div>
        <label class="label" for="default_reply">Default reply (any other message)</label>
        <textarea class="field" id="default_reply" name="default_reply" rows="4"><%= settings.default_reply || '' %></textarea>
      </div>
      <button type="submit" class="btn btn-primary">Save settings</button>
    </form>
  </main>
</body>
</html>
