<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · <%= businessName %></title>
  <%- include('../partials/styles') %>
</head>
<body class="font-sans text-ink bg-sand min-h-screen antialiased">
  <%- include('../partials/nav') %>
  <main class="max-w-md mx-auto px-4 py-16 animate-in">
    <div class="panel p-8">
      <h1 class="font-display text-3xl font-semibold mb-2">Admin Login</h1>
      <p class="text-ink/60 text-sm mb-6">QR status, live bridges, and env config (no database).</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-4 rounded-lg px-4 py-3 text-sm bg-red-50 text-red-800 border border-red-200"><%= error %></div>
      <% } %>

      <form method="POST" action="/admin/login" class="space-y-4">
        <div>
          <label class="label" for="username">Username</label>
          <input class="field" type="text" id="username" name="username" required autocomplete="username" />
        </div>
        <div>
          <label class="label" for="password">Password</label>
          <input class="field" type="password" id="password" name="password" required autocomplete="current-password" />
        </div>
        <button type="submit" class="btn btn-primary w-full">Sign in</button>
      </form>
    </div>
  </main>
</body>
</html>
