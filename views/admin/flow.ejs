<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · <%= businessName %></title>
  <%- include('../partials/styles') %>
</head>
<body class="font-sans text-ink bg-sand min-h-screen antialiased">
  <%- include('../partials/nav') %>
  <% if (flash) { %>
    <div class="max-w-5xl mx-auto px-4 pt-4">
      <div class="rounded-lg px-4 py-3 text-sm <%= flash.type === 'error' ? 'bg-red-50 text-red-800 border border-red-200' : 'bg-emerald-50 text-emerald-800 border border-emerald-200' %>"><%= flash.message %></div>
    </div>
  <% } %>

  <main class="max-w-5xl mx-auto px-4 py-8 space-y-8 animate-in">
    <div>
      <h1 class="font-display text-3xl font-semibold mb-2">Chat flow</h1>
      <p class="text-ink/60">Keywords that trigger automated replies. Use <code class="text-sea">{{form_link}}</code> and <code class="text-sea">{{business_name}}</code> in templates.</p>
    </div>

    <section class="panel p-6">
      <h2 class="font-semibold mb-4">Add trigger</h2>
      <form method="POST" action="/admin/flow" class="grid md:grid-cols-2 gap-4">
        <div>
          <label class="label">Keywords (comma-separated)</label>
          <input class="field" name="trigger_keyword" placeholder="hi,hello,hey" required />
        </div>
        <div>
          <label class="label">Sort order</label>
          <input class="field" type="number" name="sort_order" value="0" />
        </div>
        <div class="md:col-span-2">
          <label class="label">Response template</label>
          <textarea class="field font-mono text-sm" name="response_template" rows="4" required placeholder="Welcome… {{form_link}}"></textarea>
        </div>
        <div>
          <button class="btn btn-primary" type="submit">Add flow</button>
        </div>
      </form>
    </section>

    <section class="space-y-4">
      <% flows.forEach(function (f) { %>
        <form method="POST" action="/admin/flow/<%= f.id %>" class="panel p-5 space-y-3">
          <div class="grid md:grid-cols-3 gap-3">
            <div class="md:col-span-2">
              <label class="label">Keywords</label>
              <input class="field" name="trigger_keyword" value="<%= f.trigger_keyword %>" />
            </div>
            <div>
              <label class="label">Sort</label>
              <input class="field" type="number" name="sort_order" value="<%= f.sort_order %>" />
            </div>
          </div>
          <div>
            <label class="label">Response</label>
            <textarea class="field font-mono text-sm" name="response_template" rows="4"><%= f.response_template %></textarea>
          </div>
          <div class="flex flex-wrap items-center justify-between gap-3">
            <label class="text-sm flex items-center gap-2">
              <input type="checkbox" name="is_active" value="1" <%= f.is_active ? 'checked' : '' %> />
              Active
            </label>
            <div class="flex gap-2">
              <button class="btn btn-primary" type="submit">Save</button>
              <button class="btn btn-ghost text-coral" type="submit" name="_action" value="delete" onclick="return confirm('Delete this flow?')">Delete</button>
            </div>
          </div>
        </form>
      <% }) %>
    </section>
  </main>
</body>
</html>
