<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · <%= businessName %></title>
  <%- include('../partials/styles') %>
</head>
<body class="font-sans text-ink bg-sand min-h-screen antialiased">
  <%- include('../partials/nav') %>
  <% if (flash) { %>
    <div class="max-w-5xl mx-auto px-4 pt-4">
      <div class="rounded-lg px-4 py-3 text-sm <%= flash.type === 'error' ? 'bg-red-50 text-red-800 border border-red-200' : 'bg-emerald-50 text-emerald-800 border border-emerald-200' %>"><%= flash.message %></div>
    </div>
  <% } %>

  <main class="max-w-5xl mx-auto px-4 py-8 space-y-8 animate-in">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="font-display text-3xl font-semibold">Dashboard</h1>
        <p class="text-ink/60">In-memory only — cleared on restart</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/" class="btn btn-ghost">QR Page</a>
        <form method="POST" action="/admin/whatsapp/logout">
          <button class="btn btn-ghost text-coral" type="submit">Relink WhatsApp</button>
        </form>
        <form method="POST" action="/admin/whatsapp/reset-session" onsubmit="return confirm('Wipe WhatsApp auth files and restart?');">
          <button class="btn btn-ghost text-coral" type="submit">Reset WA auth</button>
        </form>
      </div>
    </div>

    <div class="panel p-5 flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <span class="status-dot status-<%= waStatus.status %>"></span>
        <div>
          <div class="font-semibold capitalize">WhatsApp: <%= waStatus.status.replace(/_/g, ' ') %></div>
          <div class="text-sm text-ink/60">
            <% if (waStatus.info && waStatus.info.phone) { %>
              +<%= waStatus.info.phone %><%= waStatus.info.pushname ? ' · ' + waStatus.info.pushname : '' %>
            <% } else { %>
              Not connected — open the QR page to scan
            <% } %>
          </div>
        </div>
      </div>
      <div class="text-sm text-ink/60 text-right">
        <div>Company: <%= companyPhone ? '+' + companyPhone : 'not set' %></div>
        <div>Pending forms: <%= memory.pendingForms %> · Live chats: <%= memory.activeBridges %></div>
      </div>
    </div>

    <section class="panel p-5">
      <h2 class="font-display text-xl font-semibold mb-4">Active bridges (RAM)</h2>
      <% if (!bridges.length) { %>
        <p class="text-sm text-ink/45">No live chats right now.</p>
      <% } else { %>
        <div class="table-wrap">
          <table class="data">
            <thead>
              <tr>
                <th>Code</th>
                <th>Customer</th>
                <th>Opened</th>
              </tr>
            </thead>
            <tbody>
              <% bridges.forEach(function (b) { %>
                <tr>
                  <td><%= b.code %></td>
                  <td>+<%= b.customerPhone %></td>
                  <td class="text-xs text-ink/45"><%= new Date(b.openedAt).toISOString() %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>
