<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · <%= businessName %></title>
  <%- include('../partials/styles') %>
</head>
<body class="font-sans text-ink bg-sand min-h-screen antialiased">
  <%- include('../partials/nav') %>
  <% if (flash) { %>
    <div class="max-w-5xl mx-auto px-4 pt-4">
      <div class="rounded-lg px-4 py-3 text-sm <%= flash.type === 'error' ? 'bg-red-50 text-red-800 border border-red-200' : 'bg-emerald-50 text-emerald-800 border border-emerald-200' %>"><%= flash.message %></div>
    </div>
  <% } %>

  <main class="max-w-5xl mx-auto px-4 py-8 space-y-8 animate-in">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="font-display text-3xl font-semibold">Dashboard</h1>
        <p class="text-ink/60">Welcome, <%= admin %></p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a href="/" class="btn btn-ghost">QR Page</a>
        <form method="POST" action="/admin/whatsapp/logout">
          <button class="btn btn-ghost text-coral" type="submit">Relink WhatsApp</button>
        </form>
        <form method="POST" action="/admin/whatsapp/reset-session" onsubmit="return confirm('Wipe LocalAuth session files and restart WhatsApp client?');">
          <button class="btn btn-ghost text-coral" type="submit">Reset session files</button>
        </form>
      </div>
    </div>

    <div class="panel p-5 flex flex-wrap items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <span class="status-dot status-<%= waStatus.status %>"></span>
        <div>
          <div class="font-semibold capitalize">WhatsApp: <%= waStatus.status.replace(/_/g, ' ') %></div>
          <div class="text-sm text-ink/60">
            <% if (waStatus.info && waStatus.info.phone) { %>
              +<%= waStatus.info.phone %><%= waStatus.info.pushname ? ' · ' + waStatus.info.pushname : '' %>
            <% } else { %>
              Not connected — open the QR page to scan
            <% } %>
          </div>
        </div>
      </div>
      <div class="text-right">
        <div class="text-xs uppercase tracking-wide text-ink/45 font-semibold">Messages logged</div>
        <div class="font-display text-2xl font-semibold"><%= messageCount %></div>
      </div>
    </div>

    <section class="panel p-5">
      <h2 class="font-display text-xl font-semibold mb-4">Recent messages</h2>
      <div class="space-y-3 max-h-96 overflow-y-auto">
        <% if (!messages.length) { %>
          <p class="text-sm text-ink/45">No messages logged yet.</p>
        <% } %>
        <% messages.forEach(function (m) { %>
          <div class="text-sm border-b border-ink/5 pb-3">
            <div class="flex justify-between gap-2 text-xs text-ink/45 mb-1">
              <span><%= m.direction === 'in' ? '← In' : '→ Out' %> · +<%= m.phone %></span>
              <span><%= m.created_at %></span>
            </div>
            <div class="whitespace-pre-wrap text-ink/80"><%= m.body %></div>
          </div>
        <% }) %>
      </div>
    </section>
  </main>
</body>
</html>
