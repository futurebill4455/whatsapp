PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
NODE_ENV=development

# Browser: uses @sparticuz/chromium on Linux/Render (no Chrome download).
# Optional override for local Chrome:
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# USE_SPARTICUZ_CHROMIUM=1
# Speed (default on Linux/Render): --single-process. Disable if frame-detach storms:
# PUPPETEER_NO_SINGLE_PROCESS=1
# PUPPETEER_SINGLE_PROCESS=1
# Chromium V8 heap cap (MB) for free-tier RAM:
# CHROMIUM_MAX_OLD_SPACE_MB=512
# Timeouts (ms) — keep high on free tier so post-QR sync does not abort:
# PUPPETEER_PROTOCOL_TIMEOUT=600000
# PUPPETEER_TIMEOUT=300000
# WA_AUTH_TIMEOUT_MS=600000
# WA_TAKEOVER_TIMEOUT_MS=120000
# WA_LOADING_STUCK_MS=120000
# Message queue (serial processing to avoid OOM):
# WA_MSG_QUEUE_MAX=40
# WA_MSG_YIELD_MS=50
# WA_SEEN_MAX=200
# WA_SEEN_TTL_MS=90000
# WA_INIT_RETRIES=4
# WA_INJECT_RETRIES=6
# WA_WAIT_RETRIES=5
# WA_QR_MAX_RETRIES=20
# WA_WEB_VERSION_CACHE=local
