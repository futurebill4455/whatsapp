PORT=3000
HOST=0.0.0.0
BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
NODE_ENV=development

# Optional fallback company desk (prefer Catalog → company desk_phone)
# COMPANY_PHONE=919999999999

# === 2GB VPS / Chromium ===
WA_INIT_DELAY_MS=1000
CHROMIUM_MAX_OLD_SPACE_MB=768
# Leave PUPPETEER_SINGLE_PROCESS unset unless you know you need it
# PUPPETEER_NO_SINGLE_PROCESS=1
# PUPPETEER_PROTOCOL_TIMEOUT=600000
# PUPPETEER_TIMEOUT=300000
# WA_AUTH_TIMEOUT_MS=600000
# WA_TAKEOVER_TIMEOUT_MS=120000
# WA_LOADING_STUCK_MS=120000
# WA_MSG_QUEUE_MAX=25
# WA_MSG_YIELD_MS=40
# WA_INIT_RETRIES=3
# WA_QR_MAX_RETRIES=20
# WA_WEB_VERSION_CACHE=local
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Render free tier tip: WA_INIT_DELAY_MS=3000 and CHROMIUM_MAX_OLD_SPACE_MB=384
