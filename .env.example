PORT=3000
HOST=0.0.0.0
BASE_URL=http://localhost:3000
SESSION_SECRET=change-this-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!
NODE_ENV=development

# Required: company WhatsApp number (country code + digits, no +)
COMPANY_PHONE=919999999999
BUSINESS_NAME=WhatsApp Bot

# Optional messaging
# TRIGGER_KEYWORDS=hi,hello,hey,start
# CLOSE_KEYWORDS=close,stop,end
# LINK_MESSAGE=Welcome to *{{business_name}}*! 👋\n\nPlease fill this short form:\n{{form_link}}
# FORM_INTRO=Please fill in your details.
# CONFIRMATION_PROMPT=Please confirm:\n\n{{summary}}\n\nReply *Yes* or *No*.
# SUCCESS_MESSAGE=Connected! Send *close* anytime to end.
# CANCEL_MESSAGE=Cancelled. Send *Hi* to start again.
# CLOSE_MESSAGE=Chat closed. Send *Hi* anytime to start again.
# COMPANY_NOTIFY_TEMPLATE=📋 *New enquiry* [#{{code}}]\n\n{{summary}}\n\nReply here (quote or [#{{code}}]).

# In-memory limits
# FORM_TTL_MS=7200000
# BRIDGE_TTL_MS=43200000
# MAX_PENDING_FORMS=80
# MAX_BRIDGES=40

# === Render / Chromium (low RAM) ===
# WA_INIT_DELAY_MS=3000
# CHROMIUM_MAX_OLD_SPACE_MB=384
# PUPPETEER_NO_SINGLE_PROCESS=1
# PUPPETEER_PROTOCOL_TIMEOUT=600000
# PUPPETEER_TIMEOUT=300000
# WA_AUTH_TIMEOUT_MS=600000
# WA_TAKEOVER_TIMEOUT_MS=120000
# WA_LOADING_STUCK_MS=120000
# WA_MSG_QUEUE_MAX=25
# WA_MSG_YIELD_MS=40
# WA_SEEN_MAX=120
# WA_SEEN_TTL_MS=60000
# WA_INIT_RETRIES=3
# WA_INJECT_RETRIES=4
# WA_WAIT_RETRIES=4
# WA_QR_MAX_RETRIES=20
# WA_WEB_VERSION_CACHE=local
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
