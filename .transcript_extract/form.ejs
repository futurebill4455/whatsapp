<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Insurance Form · <%= businessName %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --ink: #0f1f2e;
      --sea: #0d7377;
      --sea-d: #095456;
      --sand: #f7f4ef;
      --mist: #e8eef3;
      --border: rgba(15,31,46,0.14);
      --radius: 0.6rem;
      --coral: #c45c26;
    }

    body {
      margin: 0;
      font-family: "DM Sans", system-ui, sans-serif;
      background: var(--sand);
      color: var(--ink);
      min-height: 100vh;
    }

    header {
      background: rgba(255,255,255,0.9);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      padding: 0 1rem;
      height: 52px;
      display: flex;
      align-items: center;
    }

    header span { font-weight: 700; font-size: 1rem; }

    main {
      max-width: 560px;
      margin: 0 auto;
      padding: 2rem 1rem 4rem;
    }

    h1 { font-size: 1.6rem; font-weight: 700; margin: 0 0 0.35rem; }
    .intro { color: rgba(15,31,46,0.6); margin: 0 0 1.75rem; font-size: 0.9rem; }

    .card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      box-shadow: 0 1px 3px rgba(15,31,46,0.05);
    }

    .step { display: none; }
    .step.active { display: block; }

    .step-header {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin-bottom: 1.25rem;
    }

    .step-badge {
      width: 26px; height: 26px; border-radius: 999px;
      background: var(--sea); color: #fff;
      font-size: 0.75rem; font-weight: 700;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .step-label { font-weight: 600; font-size: 0.95rem; }

    .field-group { margin-bottom: 1.1rem; }
    .field-group:last-child { margin-bottom: 0; }

    label {
      display: block;
      font-size: 0.8rem;
      font-weight: 600;
      margin-bottom: 0.3rem;
      color: rgba(15,31,46,0.7);
      text-transform: uppercase;
      letter-spacing: 0.03em;
    }

    input[type="text"], input[type="number"], input[type="date"],
    select, textarea {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 0.45rem;
      padding: 0.6rem 0.8rem;
      font-size: 0.95rem;
      font-family: inherit;
      background: #fff;
      color: var(--ink);
      transition: border-color 0.15s;
      appearance: auto;
    }

    input:focus, select:focus { outline: none; border-color: var(--sea); box-shadow: 0 0 0 3px rgba(13,115,119,0.12); }

    .member-card {
      border: 1px solid var(--mist);
      border-radius: 0.5rem;
      padding: 1rem;
      margin-bottom: 0.75rem;
      background: var(--sand);
    }

    .member-title {
      font-size: 0.85rem;
      font-weight: 700;
      margin-bottom: 0.75rem;
      color: var(--sea);
    }

    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.4rem;
      padding: 0.65rem 1.25rem;
      border-radius: var(--radius);
      font-size: 0.9rem;
      font-weight: 700;
      cursor: pointer;
      border: none;
      transition: background 0.15s;
      font-family: inherit;
    }

    .btn-primary { background: var(--sea); color: #fff; width: 100%; font-size: 1rem; padding: 0.8rem; }
    .btn-primary:hover { background: var(--sea-d); }
    .btn-primary:disabled { opacity: 0.45; cursor: not-allowed; }
    .btn-outline { background: transparent; border: 1px solid var(--border); color: var(--ink); }
    .btn-outline:hover { background: var(--mist); }

    .nav-row { display: flex; gap: 0.5rem; margin-top: 1rem; }
    .nav-row .btn { flex: 1; }

    .flash {
      padding: 0.7rem 1rem;
      border-radius: 0.45rem;
      font-size: 0.88rem;
      margin-bottom: 1.25rem;
    }

    .flash-error { background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; }
    .flash-success { background: #f0fdf4; color: #166534; border: 1px solid #bbf7d0; }

    .note {
      font-size: 0.78rem;
      color: rgba(15,31,46,0.45);
      text-align: center;
      margin-top: 1rem;
    }

    .progress-bar {
      height: 4px;
      background: var(--mist);
      border-radius: 999px;
      margin-bottom: 1.5rem;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: var(--sea);
      border-radius: 999px;
      transition: width 0.3s;
    }

    .section-note {
      font-size: 0.8rem;
      color: rgba(15,31,46,0.5);
      margin-top: 0.4rem;
    }
  </style>
</head>
<body>
  <header>
    <span><%= businessName %></span>
  </header>

  <main>
    <h1>Insurance enquiry</h1>
    <p class="intro"><%= formIntro %></p>

    <% if (typeof flash !== 'undefined' && flash && flash.message) { %>
      <div class="flash flash-<%= flash.type === 'error' ? 'error' : 'success' %>">
        <%= flash.message %>
      </div>
    <% } %>

    <form method="POST" action="/form/<%= submission.token %>" id="ins-form">
      <!-- Always posted (synced from Step 1) -->
      <input type="hidden" name="customer_name" id="hidden_customer_name" value="" />
      <input type="hidden" name="insurance_type" id="hidden_insurance_type" value="" />

      <!-- Progress bar -->
      <div class="progress-bar"><div class="progress-fill" id="prog" style="width:20%"></div></div>

      <!-- ═══ STEP 1: Basic details + product selection ═══ -->
      <div class="card step active" id="step-1">
        <div class="step-header">
          <div class="step-badge">1</div>
          <div class="step-label">Your details & product</div>
        </div>

        <div class="field-group">
          <label for="customer_name">Full name</label>
          <input type="text" id="customer_name" required maxlength="120" placeholder="As on policy documents" />
        </div>

        <div class="field-group">
          <label for="insurance_type">Insurance type</label>
          <select id="insurance_type" required>
            <option value="">Select…</option>
            <option value="Health">Health Insurance</option>
            <option value="Vehicle">Vehicle Insurance</option>
          </select>
        </div>

        <div class="nav-row">
          <button type="button" class="btn btn-primary" id="btn-step1-next" disabled>Continue →</button>
        </div>
      </div>

      <!-- ═══ STEP 2a: Health — member count ═══ -->
      <div class="card step" id="step-2-health">
        <div class="step-header">
          <div class="step-badge">2</div>
          <div class="step-label">Health — number of members</div>
        </div>

        <div class="field-group">
          <label for="member_count">How many members to cover?</label>
          <select id="member_count" name="member_count">
            <option value="1">1 member</option>
            <option value="2">2 members</option>
            <option value="3">3 members</option>
            <option value="4">4 members</option>
            <option value="5">5 members</option>
          </select>
          <p class="section-note">Individual fields will appear for each member.</p>
        </div>

        <div class="nav-row">
          <button type="button" class="btn btn-outline" onclick="goStep('step-1')">← Back</button>
          <button type="button" class="btn btn-primary" onclick="buildMemberFields()">Continue →</button>
        </div>
      </div>

      <!-- ═══ STEP 3: Health member details (generated) ═══ -->
      <div class="card step" id="step-3-health">
        <div class="step-header">
          <div class="step-badge">3</div>
          <div class="step-label">Member details</div>
        </div>

        <div id="member-fields-container">
          <!-- generated by JS -->
        </div>

        <div class="nav-row">
          <button type="button" class="btn btn-outline" onclick="goStep('step-2-health')">← Back</button>
          <button type="button" class="btn btn-primary" onclick="goStep('step-4-health')">Continue →</button>
        </div>
      </div>

      <!-- ═══ STEP 4: Health — coverage & company ═══ -->
      <div class="card step" id="step-4-health">
        <div class="step-header">
          <div class="step-badge">4</div>
          <div class="step-label">Coverage &amp; preferred company</div>
        </div>

        <div class="field-group">
          <label for="coverage_amount">Desired coverage amount</label>
          <select id="coverage_amount" name="coverage_amount">
            <option value="">Select…</option>
            <% (coverageOptions || ['₹2 Lakh','₹3 Lakh','₹5 Lakh','₹10 Lakh','₹25 Lakh','₹50 Lakh','₹1 Crore']).forEach(function(o){ %>
              <option value="<%= o %>"><%= o %></option>
            <% }) %>
          </select>
        </div>

        <div class="field-group">
          <label for="company_health">Preferred company</label>
          <select id="company_health" name="company_health">
            <option value="">Select company…</option>
            <% (healthCompanies || []).forEach(function(c){ %>
              <option value="<%= c.name %>"><%= c.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="nav-row">
          <button type="button" class="btn btn-outline" onclick="goStep('step-3-health')">← Back</button>
          <button type="submit" class="btn btn-primary" id="btn-submit-health">Submit details ✓</button>
        </div>
        <p class="note">You will receive a WhatsApp confirmation — reply <strong>Yes</strong> to confirm.</p>
      </div>

      <!-- ═══ STEP 2b: Vehicle details ═══ -->
      <div class="card step" id="step-2-vehicle">
        <div class="step-header">
          <div class="step-badge">2</div>
          <div class="step-label">Vehicle details</div>
        </div>

        <div class="field-group">
          <label for="vehicle_model">Vehicle make &amp; model</label>
          <input type="text" id="vehicle_model" name="vehicle_model" maxlength="120" placeholder="e.g. Hyundai Creta 2021" />
        </div>

        <div class="row">
          <div class="field-group">
            <label for="manufacturing_year">Manufacturing year</label>
            <input type="number" id="manufacturing_year" name="manufacturing_year" min="1980" max="2030" placeholder="e.g. 2021" />
          </div>
          <div class="field-group">
            <label for="policy_type">Policy type</label>
            <select id="policy_type" name="policy_type">
              <option value="">Select…</option>
              <option value="Comprehensive">Comprehensive</option>
              <option value="Third Party">Third Party</option>
              <option value="Own Damage">Own Damage</option>
            </select>
          </div>
        </div>

        <div class="field-group">
          <label for="company_vehicle">Preferred company</label>
          <select id="company_vehicle" name="company_vehicle">
            <option value="">Select company…</option>
            <% (vehicleCompanies || []).forEach(function(c){ %>
              <option value="<%= c.name %>"><%= c.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="nav-row">
          <button type="button" class="btn btn-outline" onclick="goStep('step-1')">← Back</button>
          <button type="submit" class="btn btn-primary">Submit details ✓</button>
        </div>
        <p class="note">You will receive a WhatsApp confirmation — reply <strong>Yes</strong> to confirm.</p>
      </div>

    </form>
  </main>

  <script>
    var TOTAL_STEPS_HEALTH = 4;
    var TOTAL_STEPS_VEHICLE = 2;

    function goStep(id) {
      document.querySelectorAll('.step').forEach(function(el){ el.classList.remove('active'); });
      var target = document.getElementById(id);
      if (target) target.classList.add('active');
      updateProgress();
      window.scrollTo(0, 0);
    }

    function updateProgress() {
      var active = document.querySelector('.step.active');
      var insType = document.getElementById('insurance_type').value;
      var total = insType === 'Vehicle' ? TOTAL_STEPS_VEHICLE : TOTAL_STEPS_HEALTH;
      var stepNum = active ? parseInt(active.id.replace(/\D/g,'').slice(0,1) || '1') : 1;
      document.getElementById('prog').style.width = Math.round((stepNum / total) * 100) + '%';
    }

    // Step 1 — enable next when both fields filled
    var typeSelect = document.getElementById('insurance_type');
    var nameInput  = document.getElementById('customer_name');
    var nextBtn    = document.getElementById('btn-step1-next');

    function checkStep1() {
      nextBtn.disabled = !(nameInput.value.trim() && typeSelect.value);
      document.getElementById('hidden_customer_name').value = nameInput.value.trim();
      document.getElementById('hidden_insurance_type').value = typeSelect.value;
    }

    typeSelect.addEventListener('change', checkStep1);
    nameInput.addEventListener('input', checkStep1);

    nextBtn.addEventListener('click', function() {
      var type = typeSelect.value;
      if (type === 'Health') {
        goStep('step-2-health');
      } else if (type === 'Vehicle') {
        goStep('step-2-vehicle');
      }
    });

    // Build per-member fieldsets
    function buildMemberFields() {
      var count = parseInt(document.getElementById('member_count').value) || 1;
      var container = document.getElementById('member-fields-container');
      container.innerHTML = '';

      for (var i = 1; i <= count; i++) {
        var card = document.createElement('div');
        card.className = 'member-card';
        card.innerHTML =
          '<div class="member-title">Member ' + i + '</div>' +
          '<div class="field-group">' +
            '<label>Full name</label>' +
            '<input type="text" name="member_name_' + i + '" required maxlength="120" placeholder="Full name" />' +
          '</div>' +
          '<div class="row">' +
            '<div class="field-group">' +
              '<label>Date of birth</label>' +
              '<input type="date" name="member_dob_' + i + '" required />' +
            '</div>' +
            '<div class="field-group">' +
              '<label>Gender</label>' +
              '<select name="member_gender_' + i + '" required>' +
                '<option value="">Select…</option>' +
                '<option value="Male">Male</option>' +
                '<option value="Female">Female</option>' +
                '<option value="Other">Other</option>' +
              '</select>' +
            '</div>' +
          '</div>';
        container.appendChild(card);
      }

      goStep('step-3-health');
    }

    // Client-side submit: only disable the opposite product's fields
    document.getElementById('ins-form').addEventListener('submit', function() {
      document.getElementById('hidden_customer_name').value = nameInput.value.trim();
      document.getElementById('hidden_insurance_type').value = typeSelect.value;

      var type = typeSelect.value;
      if (type === 'Health') {
        document.querySelectorAll('#step-2-vehicle input, #step-2-vehicle select').forEach(function(el){
          el.removeAttribute('required');
          el.disabled = true;
        });
      } else if (type === 'Vehicle') {
        document.querySelectorAll('#step-2-health input, #step-2-health select, #step-3-health input, #step-3-health select, #step-4-health input, #step-4-health select').forEach(function(el){
          el.removeAttribute('required');
          el.disabled = true;
        });
      }
    });
  </script>
</body>
</html>
